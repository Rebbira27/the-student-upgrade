        .btn-light:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(255,255,255,0.35); }
        .btn-outline { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); }
        .btn-outline:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.5); }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
        section { padding: 100px 40px; position: relative; overflow: hidden; }
        .section-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 4px; font-weight: 700; margin-bottom: 16px; }
        h2 { font-family: 'Outfit', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 18px; }
        .section-desc { font-size: 1.05rem; max-width: 550px; }
        .section-divider { max-width: 1200px; margin: 0 auto; padding: 0 40px; position: relative; z-index: 2; }
        .section-divider hr { border: none; height: 1px; background: linear-gradient(90deg, transparent, rgba(0,0,0,0.06) 20%, rgba(0,0,0,0.06) 80%, transparent); }
        .bg-cream { background: #fefcf8; color: #3d2c1e; } .bg-cream .section-label { color: #d4956a; } .bg-cream h2 { color: #2d1a0e; } .bg-cream .section-desc { color: #7a5c3e; }
        .bg-mint { background: linear-gradient(170deg, #f0faf5 0%, #e8f5ef 100%); color: #1a3a2a; } .bg-mint .section-label { color: #2d8a5e; } .bg-mint h2 { color: #0e2a1a; } .bg-mint .section-desc { color: #4a7a5e; }
        .bg-lavender { background: linear-gradient(170deg, #f8f6ff 0%, #f0edff 100%); color: #2a1a3a; } .bg-lavender .section-label { color: #7c5abf; } .bg-lavender h2 { color: #1a0a2e; } .bg-lavender .section-desc { color: #5a4a7a; }
        .bg-white-sec { background: #ffffff; color: #1a1a2e; } .bg-white-sec .section-label { color: #6366f1; } .bg-white-sec .section-desc { color: #555; }
        .bg-dark { background: #0f0c29; color: #fff; } .bg-dark .section-label { color: #a78bfa; } .bg-dark h2 { color: #fff; } .bg-dark .section-desc { color: #a5b4fc; }
        .bento { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1200px; margin: 0 auto; }
        .bento-card { border-radius: 24px; padding: 36px; position: relative; overflow: hidden; transition: all 0.5s cubic-bezier(0.16,1,0.3,1); cursor: default; }
        .bento-card:hover { transform: translateY(-8px) scale(1.01); box-shadow: 0 30px 70px rgba(0,0,0,0.15); }
        .bento-2col { grid-column: span 2; } .bento-2row { grid-row: span 2; }
        .bento-card h3 { font-family: 'Outfit', sans-serif; font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }
        .bento-card p { font-size: 0.9rem; margin-bottom: 16px; opacity: 0.85; }
        .bento-card .btn { padding: 10px 22px; font-size: 0.85rem; display: inline-block; text-decoration: none; }
        .card-blue { background: linear-gradient(145deg, #eef4ff, #dce8fc); color: #1a2a4a; } .card-blue h3 { color: #1e40af; } .card-blue p { color: #3a5a8a; } .card-blue .btn { background: #1e40af; color: #fff; }
        .card-green { background: linear-gradient(145deg, #edfaf3, #d8f5e6); color: #1a3a2a; } .card-green h3 { color: #166534; } .card-green p { color: #3a6a4a; } .card-green .btn { background: #166534; color: #fff; }
        .card-peach { background: linear-gradient(145deg, #fff6f0, #ffe8da); color: #3a1a0a; } .card-peach h3 { color: #c2410c; } .card-peach p { color: #7a3a1e; } .card-peach .btn { background: #c2410c; color: #fff; }
        .card-purple { background: linear-gradient(145deg, #f8f6ff, #ede4ff); color: #2a1a3a; } .card-purple h3 { color: #6d28d9; } .card-purple p { color: #5a3a7a; } .card-purple .btn { background: #6d28d9; color: #fff; }
