    <script>
        (function(){
            var container = document.getElementById('particles');
            var colors = ['rgba(99,102,241,0.4)','rgba(168,120,250,0.35)','rgba(52,211,153,0.3)','rgba(245,158,11,0.3)'];
            for(var i=0;i<30;i++){
                var p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random()*100 + '%';
                p.style.width = (Math.random()*8+3) + 'px';
                p.style.height = p.style.width;
                p.style.background = colors[Math.floor(Math.random()*colors.length)];
                p.style.animationDuration = (Math.random()*20+15) + 's';
                p.style.animationDelay = (Math.random()*15) + 's';
                container.appendChild(p);
            }
        })();
        (function(){
            var heroBg = document.getElementById('heroBg');
            window.addEventListener('scroll',function(){
                var scroll = window.pageYOffset;
                if(heroBg) heroBg.style.transform = 'translateY(' + (scroll * 0.3) + 'px)';
            });
        })();
        (function(){
            var counters = document.querySelectorAll('.stat-number[data-target]');
            var counted = false;
            var observer = new IntersectionObserver(function(entries){
                entries.forEach(function(entry){
                    if(entry.isIntersecting && !counted){
                        counted = true;
                        counters.forEach(function(c){
                            var target = parseInt(c.getAttribute('data-target'));
                            var duration = 1800;
                            var start = 0;
                            var startTime = null;
                            function animate(ts){
                                if(!startTime) startTime = ts;
                                var progress = Math.min((ts-startTime)/duration,1);
                                var ease = 1-Math.pow(1-progress,3);
                                c.innerText = Math.floor(ease*target);
                                if(progress<1) requestAnimationFrame(animate);
                                else c.innerText = target===999?'∞':target;
                            }
                            requestAnimationFrame(animate);
                        });
                    }
                });
            },{threshold:0.4});
            var strip = document.querySelector('.stat-strip');
            if(strip) observer.observe(strip);
        })();
        (function(){
            var reveals = document.querySelectorAll('.reveal');
            var obs = new IntersectionObserver(function(entries){
                entries.forEach(function(e,i){
                    if(e.isIntersecting) setTimeout(function(){e.target.classList.add('visible');},i*60);
                });
            },{threshold:0.12,rootMargin:'0px 0px -40px 0px'});
            reveals.forEach(function(el){obs.observe(el);});
        })();
        (function(){
            var overlay = document.getElementById('loginOverlay');
            var rp = document.getElementById('registerPanel');
            var lp = document.getElementById('loginPanel');
            var resetp = document.getElementById('resetPanel');
            if(localStorage.getItem('loggedIn')==='true'){overlay.classList.add('hidden');}
            document.getElementById('showLogin').addEventListener('click',function(e){e.preventDefault();rp.style.display='none';lp.style.display='block';resetp.style.display='none';});
            document.getElementById('showRegister').addEventListener('click',function(e){e.preventDefault();lp.style.display='none';rp.style.display='block';resetp.style.display='none';});
            document.getElementById('showReset').addEventListener('click',function(e){e.preventDefault();lp.style.display='none';rp.style.display='none';resetp.style.display='block';});
            document.getElementById('showLoginFromReset').addEventListener('click',function(e){e.preventDefault();resetp.style.display='none';lp.style.display='block';});
            document.getElementById('skipLogin').addEventListener('click',function(){overlay.classList.add('hidden');});
            document.getElementById('registerBtn').addEventListener('click',function(){
                var u=document.getElementById('regUsername').value,e=document.getElementById('regEmail').value,p=document.getElementById('regPassword').value;
                var msg=document.getElementById('regMessage');
                if(!u||!e||!p){msg.innerText='Please fill all fields.';msg.style.color='red';return;}
                msg.innerText='Creating account...';msg.style.color='#888';
                fetch('register.php',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'username='+encodeURIComponent(u)+'&email='+encodeURIComponent(e)+'&password='+encodeURIComponent(p)})
                .then(function(r){return r.text();}).then(function(d){
                    if(d==='success'){msg.innerText='Account created! You can now log in.';msg.style.color='green';rp.style.display='none';lp.style.display='block';document.getElementById('loginUsername').value=u;}
                    else{msg.innerText=d;msg.style.color='red';}
                }).catch(function(){msg.innerText='Connection error.';msg.style.color='red';});
            });
            document.getElementById('loginBtn').addEventListener('click',function(){
                var u=document.getElementById('loginUsername').value,p=document.getElementById('loginPassword').value;
                var msg=document.getElementById('loginMessage');
                if(!u||!p){msg.innerText='Enter username and password.';msg.style.color='red';return;}
                msg.innerText='Logging in...';msg.style.color='#888';
                fetch('login.php',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'username='+encodeURIComponent(u)+'&password='+encodeURIComponent(p)})
                .then(function(r){return r.text();}).then(function(d){
                    if(d.startsWith('success')){var parts=d.split('|');localStorage.setItem('loggedIn','true');localStorage.setItem('userId',parts[1]);localStorage.setItem('username',parts[2]);overlay.classList.add('hidden');}
                    else{msg.innerText=d;msg.style.color='red';}
                }).catch(function(){msg.innerText='Connection error.';msg.style.color='red';});
            });
            document.getElementById('resetBtn').addEventListener('click',function(){
                var e=document.getElementById('resetEmail').value,msg=document.getElementById('resetMessage');
                if(!e){msg.innerText='Enter your email.';msg.style.color='red';return;}
                msg.innerText='Sending...';msg.style.color='#888';
                fetch('reset_password.php',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'email='+encodeURIComponent(e)})
                .then(function(r){return r.text();}).then(function(d){msg.innerText=d.startsWith('success')?'Email sent! Check your inbox.':d;msg.style.color=d.startsWith('success')?'green':'red';});
            });
        })();
        var nav = document.getElementById('navbar');
        window.addEventListener('scroll',function(){nav.classList.toggle('scrolled',window.scrollY>50);});
    </script>
