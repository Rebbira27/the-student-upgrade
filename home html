        .stat-item { text-align: center; } .stat-number { font-family: 'Outfit', sans-serif; font-size: 3.5rem; font-weight: 900; } .stat-label { font-size: 0.9rem; font-weight: 600; margin-top: 4px; }
        .step-card { background: #fff; border: 1px solid #eee; border-radius: 20px; padding: 32px; width: 260px; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.03); transition: all 0.4s cubic-bezier(0.16,1,0.3,1); }
        .step-card:hover { transform: translateY(-10px); box-shadow: 0 20px 50px rgba(0,0,0,0.1); }
        .step-card .step-icon { font-size: 3rem; margin-bottom: 12px; transition: transform 0.3s; }
